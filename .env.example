# Atlassian OAuth credentials
# developer.atlassian.com でアプリを作成して設定する
ATLASSIAN_OAUTH_CLIENT_ID=your_client_id_here
ATLASSIAN_OAUTH_CLIENT_SECRET=your_client_secret_here

# Atlassian に要求するスコープ（スペース区切り）
# 例: read:jira-work manage:jira-project read:confluence-content.all
ATLASSIAN_OAUTH_SCOPES=read:jira-work read:confluence-content.all
